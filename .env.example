# OpenAI API Key (Required for OpenAI-compatible providers and embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL (Optional, configure when using proxy)
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic / Claude API Key (Optional, required when using the anthropic provider)
# CLAUDE_API_KEY is also accepted as an alias.
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
